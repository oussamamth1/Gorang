rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Identity documents: only the owner can read or write them.
    match /users/{uid}/{file} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Vehicle photos: public to signed-in users, writable by any signed-in
    // user (the photo path is created together with the vehicle document).
    match /vehicles/{vehicleId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
